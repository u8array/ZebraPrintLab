{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "ZebraPrintLab",
  "version": "../package.json",
  "mainBinaryName": "ZebraPrintLab",
  "identifier": "de.u8array.zebraprintlab",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "ZebraPrintLab",
        "width": 1280,
        "height": 832,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self'; connect-src 'self' ipc: http: https:; object-src 'none'; base-uri 'self'; frame-ancestors 'none'; form-action 'self'",
      "devCsp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self'; connect-src 'self' ipc: http: https: ws://localhost:5173; object-src 'none'; base-uri 'self'; frame-ancestors 'none'; form-action 'self'"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEYzNTVGNUIzRjVERjQyMQpSV1FoOUYwL1cxODFEMW4xcVZYZndYVWlwM3lyaGYrK3FpSWN5cjBxanM1ZDdVR3B4a3Y2Y0ZsTAo=",
      "endpoints": [
        "https://github.com/u8array/ZebraPrintLab/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "publisher": "u8array",
    "copyright": "© 2026 u8array",
    "license": "MIT",
    "homepage": "https://github.com/u8array/ZebraPrintLab",
    "category": "Productivity",
    "shortDescription": "ZPL label designer",
    "longDescription": "Visual designer for Zebra ZPL printer labels with live preview and ZPL import/export.",
    "macOS": {
      "signingIdentity": "-"
    },
    "resources": ["THIRD-PARTY-LICENSES-RUST.html"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "files": {
          "/usr/lib/udev/rules.d/99-zebraprintlab.rules": "packaging/udev/99-zebraprintlab.rules"
        },
        "postInstallScript": "packaging/linux/postinst"
      },
      "rpm": {
        "files": {
          "/usr/lib/udev/rules.d/99-zebraprintlab.rules": "packaging/udev/99-zebraprintlab.rules"
        },
        "postInstallScript": "packaging/linux/postinst"
      }
    }
  }
}
