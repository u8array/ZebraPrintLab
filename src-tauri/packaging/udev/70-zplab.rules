# Zebra USB label printers: grant the active desktop session access to the
# usblp char device (/dev/usb/lpN) the app writes. Scoped to that node only,
# not the whole USB device, since we never touch raw libusb.
# Numbered below 73-seat-late.rules so the uaccess tag is set before logind's
# uaccess builtin runs (a higher number applies the tag too late, no ACL).
SUBSYSTEM=="usbmisc", KERNEL=="lp[0-9]*", ATTRS{idVendor}=="0a5f", TAG+="uaccess"
