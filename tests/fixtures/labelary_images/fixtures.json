{
  "test_cases": [
    {
      "id": "barcode_code128_standard",
      "zpl_input": "^XA^BY2^FO50,50^BCN,100,N,N,N^FD123456^FS^XZ",
      "expected_bounds": {
        "x": 50,
        "y": 50,
        "width": 202,
        "height": 100
      },
      "image_ref": "barcode_code128_standard.png"
    },
